    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },
    "pulseaudio": {
        "format": "{icon}    {volume}%",
        "format-bluetooth": "{icon} {volume}% пКФ {format_source}",
        "format-bluetooth-muted": "пЪ©  {icon} пКФ {format_source}",
        "format-muted": "пЪ©  {format_source}",
        "format-source": "пД∞ {volume}%",
        "format-source-muted": "пД±",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "пЗЂ   {essid} ({signalStrength}%)",
        "format-ethernet": "{ipaddr}/{cidr} пЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
        "format-linked": "{ifname} (No IP) пЮЦ",
        "format-disconnected": "Disconnected вЪ†",
	"on-click": "sh ~/scripts/rofi-wifi-menu/rofi-wifi-menu.sh"
	 
    },
    "cpu": {
        "format": "пЛЫ  {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "пГЙ  {}%",
	"tooltip": true
    },
    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 100,
        "format-critical": "пЛЗ {temperatureC}",
        "format": "пЛЙ {temperatureC}¬∞C"
    },
    "hyprland/language": {
       "format": "пВђ  {}",
       "format-en": "EN",
       "format-ru": "RU"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "пЧІ  {capacity}%",
        "format-plugged": "пЗ¶  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "clock": {
        "format": "{:%H:%M:%S | %a %d/%m/%Y} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}",
	"interval": 1,
	"smooth-scrolling-threshold": 1,
	"calendar": {
	    "mode": "month",
	    "on-scroll": 1,
	    "format": {
	        "weeks": "{:%W}"
	    }
	},
	"actions": {
	    "on-scroll-up": "shift_up",
	    "on-scroll-down": "shift_down"
	}
    },
    "tray": {
        "icon-size": 18,
        "spacing": 5
    },
    "custom/display": {
      "return-type": "json",
      "exec": "$XDG_CONFIG_HOME/waybar/scripts/display_status.sh",
      "interval": 2,
      "on-click": "$XDG_CONFIG_HOME/waybar/scripts/display_toggle.sh",
      "tooltip": true
    },
    "custom/audio-toggle": {
        "exec": "$XDG_CONFIG_HOME/waybar/scripts/audio-status.sh",
        "interval": 2,
        "on-click": "$XDG_CONFIG_HOME/waybar/scripts/audio-toggle.sh",
        "format": "{}"
    },
	"custom/monitor-brightness": {
	  "exec": "$XDG_CONFIG_HOME/waybar/scripts/monitor-brightness.sh",
	  "return-type": "json",
	  "interval": 3600,
	  "signal": 8,
	  "on-scroll-up": "$XDG_CONFIG_HOME/waybar/scripts/monitor-brightness.sh up && pkill -RTMIN+8 waybar",
	  "on-scroll-down": "$XDG_CONFIG_HOME/waybar/scripts/monitor-brightness.sh down && pkill -RTMIN+8 waybar"
	}
}
